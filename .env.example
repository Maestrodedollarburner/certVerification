PORT=3000
# Local dev: use localhost MongoDB, or set USE_MEMORY_DB=true (dev only)
MONGODB_URI=mongodb://127.0.0.1:27017/certificate_verification
USE_MEMORY_DB=false
# Production (Railway/Render/etc.): set MONGODB_URI to MongoDB Atlas connection string, USE_MEMORY_DB=false
REQUIRE_BLOCKCHAIN=false
CORS_ORIGIN=
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
GANACHE_URL=http://127.0.0.1:7545
PRIVATE_KEY=your_ganache_account_private_key
CONTRACT_ADDRESS=
APP_URL=http://localhost:3000
